# Monarch CLI Environment Configuration
# Copy this file to .env and update values as needed

# SolAuth Server Configuration
# Default: http://localhost:4000 (local development)
# Production: https://solauth.your-domain.com
SOLAUTH_API_URL=http://localhost:4000

# Optional: Data directory for agents, dossiers, notary records
# Default: ~/.monarch
# MONARCH_DATA_DIR=/custom/path/.monarch

# Optional: Enable debug logging
# DEBUG=monarch:*

# Optional: Custom backend timeout (milliseconds)
# BACKEND_TIMEOUT=5000

# Optional: Log level (error, warn, info, debug)
# LOG_LEVEL=info
