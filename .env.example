# Solana Configuration
SOLANA_NETWORK=devnet # or mainnet
HELIUS_API_KEY=your_helius_api_key_here
SOLANA_MERKLE_TREE_ADDRESS=your_merkle_tree_address
SOLANA_PRIVATE_KEY=your_base58_private_key

# Database
DATABASE_URL=postgresql://user:password@host/database?sslmode=require

# Magic Link (Email-based wallet authentication)
VITE_MAGIC_PUBLISHABLE_KEY=pk_live_xxxxx # Frontend
MAGIC_SECRET_KEY=sk_live_xxxxx # Backend (optional - for Magic Link API)
WALLET_DERIVATION_SECRET=your_random_secret_key_here # REQUIRED - for deterministic wallet generation

# x402 Payment Protocol
X402_PAYMENT_ADDRESS=your_solana_wallet_address_for_payments

# CORS
CORS_ORIGIN=*
