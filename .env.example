# Backend Configuration (monarch-cli/)
SOLANA_NETWORK=devnet # or mainnet
HELIUS_API_KEY=your_helius_api_key_here
SOLANA_MERKLE_TREE_ADDRESS=your_merkle_tree_address
SOLANA_PRIVATE_KEY=your_base58_private_key

# Database
DATABASE_URL=postgresql://user:password@host/database?sslmode=require

# x402 Payment Protocol
X402_PAYMENT_ADDRESS=your_solana_wallet_address_for_payments

# CORS
CORS_ORIGIN=*

# Frontend Configuration (monarch-times/)
# Create a monarch-times/.env file with these variables:

# Privy Authentication (Get from https://console.privy.io)
# VITE_PRIVY_APP_ID=your_privy_app_id_here

# Solana Network
# VITE_SOLANA_NETWORK=devnet
# VITE_HELIUS_API_KEY=your_helius_api_key_here

# API URL (optional, defaults to production)
# VITE_API_URL=http://localhost:3000
