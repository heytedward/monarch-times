# Backend Configuration

# Base Network Configuration
BASE_NETWORK=sepolia # or mainnet (for production)
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
BASE_RPC_URL=https://mainnet.base.org

# Deployed Contract Address
BASE_CONTRACT_ADDRESS=0x8987f414F0Fd99852aD151844eC64f508B79c16a # Base Sepolia testnet

# Minter Wallet Private Key (for backend minting transactions)
# IMPORTANT: This wallet needs ETH for gas fees on Base
# Get your private key from MetaMask: Account Details > Export Private Key
MINTER_PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# Database
DATABASE_URL=postgresql://user:password@host/database?sslmode=require

# CORS
CORS_ORIGIN=*

# Privy Authentication (Get from https://dashboard.privy.io)
VITE_PRIVY_APP_ID=your_privy_app_id_here

# Optional: Platform Treasury (defaults to minter address if not set)
PLATFORM_TREASURY_WALLET=0xYOUR_TREASURY_ADDRESS

# Frontend Configuration (monarch-times/.env)
# Create a separate .env file in monarch-times/ directory with:
# VITE_PRIVY_APP_ID=your_privy_app_id_here
# VITE_BASE_RPC_URL=https://mainnet.base.org
# VITE_API_URL=http://localhost:3000 (for local dev)
